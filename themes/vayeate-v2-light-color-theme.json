    "tokenColors": [
        {
            "name": "defaultText",
            "scope": [
                "source",
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source.yaml punctuation.definition",
                "source.json punctuation.definition",
                "source.yaml punctuation.separator",
                "source.json punctuation.separator",
                "source.yaml entity.other",
                "source.regex-pipeline.obsidian string.regexp"
            ],
            "settings": {
                "foreground": "#6e7e91"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#659a69"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string",
                "source.regex-pipeline.obsidian string.regexp.pattern.obsidian"
            ],
            "settings": {
                "foreground": "#5ea35c"
            }
        },
        {
            "name": "stringEscape",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
                "text.xml punctuation.definition.tag",
                "text.xml meta.tag",
                "fenced_code.block.language",
                "markup.inline",
                "string.other.link",
                "text.html.markdown punctuation.definition",
                "text.html.markdown punctuation.definition.string",
                "text.html.markdown meta.separator",
                "source.ini punctuation",
                "source.ini punctuation.separator",
                "source.toml punctuation",
                "source.toml punctuation.separator",
                "source.regex-pipeline.obsidian string.regexp.escape.obsidian"
            ],
            "settings": {
                "foreground": "#867d50"
            }
        },
        {
            "name": "preprocessor",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
                "variable.parameter",
                "entity.name.variable.parameter",
                "entity.name.type.type-parameter",
                "storage.type.generic",
                "source.java punctuation.bracket.angle",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.unicode.obsidian"
            ],
            "settings": {
                "foreground": "#8e7d2c"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
                "source.regex-pipeline.obsidian keyword.other.filetype.obsidian",
                "source.regex-pipeline.obsidian keyword.control.rule.obsidian",
                "source.regex-pipeline.obsidian keyword.control.pattern.obsidian",
                "source.regex-pipeline.obsidian keyword.control.include.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.multiline.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.replace.subrule.obsidian"
            ],
            "settings": {
                "foreground": "#484fb5"
            }
        },
        {
            "name": "typeClass",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
                "source.ini keyword",
                "source.toml keyword",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.indices.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.allowPatternWhitespace.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.replace.allowPatternWhitespace.obsidian"
            ],
            "settings": {
                "foreground": "#068df9"
            }
        },
        {
            "name": "typeInterface",
            "scope": [
                "entity.name.type.interface",
                "heading.3 entity.name.section",
                "markup.underline.link",
                "source.ini entity.name.section",
                "source.toml entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#2bd4ab"
            }
        },
        {
            "name": "constant",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
                "source.yaml constant.language",
                "source.json constant.language",
                "heading.2 entity.name.section",
                "source.ini",
                "source.toml"
            ],
            "settings": {
                "foreground": "#ac55dd"
            }
        },
        {
            "name": "field",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable"
            ],
            "settings": {
                "foreground": "#b96926"
            }
        },
        {
            "name": "method",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function",
                "text.xml entity.name.tag",
                "source.regex-pipeline.obsidian entity.name.pattern.obsidian"
            ],
            "settings": {
                "foreground": "#fa0606"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#f61b1b"
            }
        },
        {
            "name": "docTag",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#68846a"
            }
        },
        {
            "name": "docAttr",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#4a8879"
            }
        },
        {
            "name": "docText",
            "scope": [
                "comment.block.documentation",
                "comment.block.javadoc",
                "comment.line.documentation"
            ],
            "settings": {
                "foreground": "#7a857c"
            }
        },
        {
            "name": "docParam",
            "scope": [
                "comment.block.documentation string.quoted.double",
                "comment.block.documentation punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#bea641"
            }
        },
        {
            "name": "xmlAttr",
            "scope": [
                "text.xml entity.other.attribute-name",
                "source.yaml entity.name.tag",
                "source.json support.type",
                "heading.1 entity.name.section",
                "punctuation.definition.heading",
                "source.regex-pipeline.obsidian entity.name.rule.obsidian",
                "source.regex-pipeline.obsidian entity.name.include.obsidian",
                "source.regex-pipeline.obsidian string.regexp.paren.obsidian"
            ],
            "settings": {
                "foreground": "#067ee0"
            }
        },
        {
            "name": "mdHeaderOther",
            "scope": [
                "entity.name.section"
            ],
            "settings": {
                "foreground": "#5782a5"
            }
        },
        {
            "name": "mdRefLink",
            "scope": [
                "constant.other.reference.link",
                "source.regex-pipeline.obsidian string.regexp.control.obsidian"
            ],
            "settings": {
                "foreground": "#7075c7"
            }
        },
        {
            "name": "regexOperator",
            "scope": [
                "source.regex-pipeline.obsidian keyword.control.apply.obsidian",
                "source.regex-pipeline.obsidian keyword.control.regex.pattern.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.margin.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.global.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.replace.delete.obsidian"
            ],
            "settings": {
                "foreground": "#f90f0f"
            }
        },
        {
            "name": "regexOperator2",
            "scope": [
                "source.regex-pipeline.obsidian keyword.operator.template.obsidian",
                "source.regex-pipeline.obsidian keyword.operator.options.rule.singleline.obsidian"
            ],
            "settings": {
                "foreground": "#b86927"
            }
        },
        {
            "name": "regexReplace",
            "scope": [
                "source.regex-pipeline.obsidian string.regexp.replace.obsidian"
            ],
            "settings": {
                "foreground": "#2b8b7c"
            }
        },
        {
            "name": "regexOptions3",
            "scope": [
                "source.regex-pipeline.obsidian keyword.operator.options.rule.insensitive.obsidian"
            ],
            "settings": {
                "foreground": "#ab56dd"
            }
        },
        {
            "name": "regexOptions7",
            "scope": [
                "source.regex-pipeline.obsidian keyword.operator.options.rule.vnicode.obsidian"
            ],
            "settings": {
                "foreground": "#907868"
            }
        },
        {
            "name": "regexOptions8",
            "scope": [
                "source.regex-pipeline.obsidian keyword.operator.options.rule.sticky.obsidian"
            ],
            "settings": {
                "foreground": "#748075"
            }
        },
        {
            "name": "regexLineComment",
            "scope": [
                "source.regex-pipeline.obsidian comment.line.double-colon.obsidian"
            ],
            "settings": {
                "foreground": "#6da071"
            }
        },
        {
            "name": "regexTextComment",
            "scope": [
                "source.regex-pipeline.obsidian comment.line.text.obsidian"
            ],
            "settings": {
                "foreground": "#ba8787"
            }
        }
