            "settings": {
                "foreground": "#3a4a20"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "markup.underline.link",
            ],
            "settings": {
                "foreground": "#8a6018"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "fenced_code.block.language",
                "markup.inline",
                "string.other.link",
                "text.html.markdown punctuation.definition",
                "text.html.markdown punctuation.definition.string",
                "text.html.markdown meta.separator",
            ],
            "settings": {
                "foreground": "#2a4828"
            }
        },
