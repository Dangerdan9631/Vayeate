    "tokenColors": [
        {
            "name": "Sandrock Light",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#4a4820"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#2c2010"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Sandrock Light",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#8a7850"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#7a4818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#7a4818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#4a5c28"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#3a4a20"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
            ],
            "settings": {
                "foreground": "#2a3818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name.type.interface",
            ],
            "settings": {
                "foreground": "#4a5838"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
            ],
            "settings": {
                "foreground": "#3a5028"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable",
            ],
            "settings": {
                "foreground": "#684818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
            ],
            "settings": {
                "foreground": "#1e2a10"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "variable.parameter",
                "entity.name.variable.parameter",
                "entity.name.type.type-parameter",
                "storage.type.generic",
                "source.java punctuation.bracket.angle"
            ],
            "settings": {
                "foreground": "#4a5c28"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "constant.numeric",
            ],
            "settings": {
                "foreground": "#2a4828"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag",
            ],
            "settings": {
                "foreground": "#a09070"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#807860",
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "comment.block.documentation",
                "comment.block.javadoc",
                "comment.line.documentation",
            ],
            "settings": {
                "foreground": "#8a7850",
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "comment.block.documentation string.quoted.double",
                "comment.block.documentation punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#8a4010"
            }
        },
        // =====================================================================
        // XML
        // =====================================================================
        {
            "name": "Sandrock Light",
            "scope": [
                "text.xml punctuation.definition.tag",
                "text.xml meta.tag",
            ],
            "settings": {
                "foreground": "#7a4818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "text.xml entity.name.tag",
            ],
            "settings": {
                "foreground": "#7a4010"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "text.xml entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#4a5838"
            }
        },
        // =====================================================================
        // YAML/JSON
        // =====================================================================
        {
            "name": "Sandrock Light",
            "scope": [
                "source.yaml punctuation.definition",
                "source.json punctuation.definition",
                "source.yaml punctuation.separator",
                "source.json punctuation.separator",
                "source.yaml entity.other",
            ],
            "settings": {
                "foreground": "#2c2010"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "source.yaml entity.name.tag",
                "source.json support.type",
            ],
            "settings": {
                "foreground": "#7a4818"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "source.yaml constant.language",
                "source.json constant.language",
            ],
            "settings": {
                "foreground": "#3a5028"
            }
        },
        // =====================================================================
        // Markdown
        // =====================================================================
        {
            "name": "Sandrock Light",
            "scope": [
                "heading.1 entity.name.section",
                "punctuation.definition.heading",
