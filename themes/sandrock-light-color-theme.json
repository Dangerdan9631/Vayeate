            "settings": {
                "foreground": "#8a6018"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "entity.name.section",
            ],
            "settings": {
                "foreground": "#504820"
            }
        },
        {
            "name": "Sandrock Light",
            "scope": [
                "constant.other.reference.link",
