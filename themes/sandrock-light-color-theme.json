        "inputValidation.errorForeground": "#f5efe0",
        "inputValidation.infoBackground": "#7a5818",
        "inputValidation.infoForeground": "#101008",
        "inputValidation.warningBackground": "#a04020",
        "inputValidation.warningForeground": "#f5efe0",
