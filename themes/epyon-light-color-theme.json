    "tokenColors": [
        {
            "name": "Epyon Light",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#6a3030"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Epyon Light",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#280e0e"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Epyon Light",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#886060"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#7a1818"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#8a2020"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#8a3030"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#901820"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
            ],
            "settings": {
                "foreground": "#6a1818"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "entity.name.type.interface",
            ],
            "settings": {
                "foreground": "#7a3030"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
            ],
            "settings": {
                "foreground": "#6a2828"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable",
            ],
            "settings": {
                "foreground": "#7a2828"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
            ],
            "settings": {
                "foreground": "#4a1010"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "variable.parameter",
