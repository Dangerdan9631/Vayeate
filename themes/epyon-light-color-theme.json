        "terminal.ansiBrightCyan": "#904848",
        "terminal.ansiBrightGreen": "#8a3838",
        "terminal.ansiBrightMagenta": "#a07080",
        "terminal.ansiBrightRed": "#d00000",
        "terminal.ansiBrightWhite": "#100404",
        "terminal.ansiBrightYellow": "#905828",
