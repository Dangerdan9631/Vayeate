        "extensionButton.prominentHoverBackground": "#e8cccc",
        // =====================================================================
        // Editor View
        "editor.foreground": "#280e0e",
        "editor.background": "#f8f0f0",
        "editorCursor.foreground": "#a01818",
        "editor.lineHighlightBackground": "#f4eaea",
        "editor.selectionBackground": "#ddbcbc",
        "editorLineNumber.foreground": "#9a7070",
        "editorLineNumber.activeForeground": "#9a7070",
