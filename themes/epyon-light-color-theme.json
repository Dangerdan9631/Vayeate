            "settings": {
                "foreground": "#8a3030"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "constant.numeric",
            ],
            "settings": {
                "foreground": "#802020"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag",
            ],
            "settings": {
                "foreground": "#a08080"
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#806868",
            }
        },
        {
            "name": "Epyon Light",
            "scope": [
                "comment.block.documentation",
