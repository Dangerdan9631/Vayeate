        "inputValidation.errorForeground": "#f8f0f0",
        "inputValidation.infoBackground": "#8a1818",
        "inputValidation.infoForeground": "#100404",
        "inputValidation.warningBackground": "#c00000",
        "inputValidation.warningForeground": "#f8f0f0",
