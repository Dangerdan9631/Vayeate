            "settings": {
                "foreground": "#2e5088"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag",
            ],
            "settings": {
                "foreground": "#8090a0"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#5a7898",
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
