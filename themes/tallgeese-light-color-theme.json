    "tokenColors": [
        {
            "name": "Tallgeese Light",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#3a5070"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#2c3440"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Tallgeese Light",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#7a8898"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#7a5020"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#7a4820"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#3a6090"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#2c4870"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
            ],
            "settings": {
                "foreground": "#1e3050"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.name.type.interface",
            ],
            "settings": {
                "foreground": "#3a5878"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
            ],
            "settings": {
                "foreground": "#3a5878"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable",
            ],
            "settings": {
                "foreground": "#6a5020"
            }
        },
        {
            "name": "Tallgeese Light",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
