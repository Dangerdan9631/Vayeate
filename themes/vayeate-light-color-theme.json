    "tokenColors": [
        {
            "name": "Unmarked",
            "scope": [
                "source"
            ],
            "settings": {
                "foreground": "#009100"
            }
        },
        {
            "name": "Default",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source"
            ],
            "settings": {
                "foreground": "#6e7e91"
            }
        },
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#548057"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#437442"
            }
        },
        {
            "name": "StringEscapeCharacter",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation"
            ],
            "settings": {
                "foreground": "#867d50"
            }
        },
        {
            "name": "Preprocessor",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation"
            ],
            "settings": {
                "foreground": "#665a20"
            }
        },
        {
            "name": "Keyword",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language"
            ],
            "settings": {
                "foreground": "#474fb5"
            }
        },
        {
            "name": "Class",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object"
            ],
            "settings": {
                "foreground": "#045ca2"
            }
        },
        {
            "name": "Interface",
            "scope": [
                "entity.name.type.interface"
            ],
            "settings": {
                "foreground": "#1d8c71"
            }
        },
        {
            "name": "Constant",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum"
            ],
            "settings": {
                "foreground": "#ac55dd"
            }
        },
        {
            "name": "Field",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable"
            ],
            "settings": {
                "foreground": "#b86926"
            }
        },
        {
            "name": "Method",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
            ],
            "settings": {
                "foreground": "#fa0606"
            }
        },
        {
            "name": "Parameter",
            "scope": [
                "variable.parameter",
                "entity.name.variable.parameter",
                "entity.name.type.type-parameter",
                "storage.type.generic",
                "source.java punctuation.bracket.angle"
            ],
            "settings": {
                "foreground": "#665a20"
            }
        },
        {
            "name": "Number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#f61b1b"
            }
        },
        {
            "name": "DocCommentTagName",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#4b5f4d"
            }
        },
        {
            "name": "DocCommentAttributeName",
            "scope": [
                "entity.other.attribute-name"
