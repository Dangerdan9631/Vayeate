            "settings": {
                "foreground": "#979bd6"
            }
        },
        {
            "name": "Markdown Links",
            "scope": [
                "markup.underline.link",
            ],
            "settings": {
                "foreground": "#26b995"
            }
        },
        {
            "name": "Markdown Punctuation",
            "scope": [
                "fenced_code.block.language",
                "markup.inline",
                "string.other.link",
                "text.html.markdown punctuation.definition",
