            "settings": {
                "foreground": "#9ab0c4"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag",
            ],
            "settings": {
                "foreground": "#8c9aa8"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "entity.other.attribute-name",
