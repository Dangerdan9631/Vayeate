    "tokenColors": [
        {
            "name": "Tallgeese",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#96a8bc"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Tallgeese",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#c4cad0"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Tallgeese",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#5a6778"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#a07c4b"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#a88040"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#8aaec4"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#a8bcd0"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
            ],
            "settings": {
                "foreground": "#c8ccce"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "entity.name.type.interface",
            ],
            "settings": {
                "foreground": "#a8b4c4"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
            ],
            "settings": {
                "foreground": "#a0b0c4"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable",
            ],
            "settings": {
                "foreground": "#a07c4b"
            }
        },
        {
            "name": "Tallgeese",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
