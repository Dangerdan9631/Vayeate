        // =====================================================================
        // Properties
        // =====================================================================
        {
            "name": "Properties Name",
            "scope": [
                "source.ini keyword",
            ],
            "settings": {
                "foreground": "#35a2fa"
            }
        },
        {
            "name": "Section Title",
            "scope": [
                "source.ini entity.name.section",
            ],
            "settings": {
                "foreground": "#26b995"
            }
        },
        {
            "name": "Properties Value",
            "scope": [
                "source.ini",
