            ],
            "settings": {
                "foreground": "#7c8c92"
            }
        },
        {
            "name": "YamlConstant",
            "scope": [
                "source.yaml constant.language",
                "source.json constant.language",
            ],
            "settings": {
                "foreground": "#b39f63"
            }
        },
