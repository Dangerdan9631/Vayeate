    "tokenColors": [
        {
            "name": "Unmarked",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#00ff00"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Default",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#9faab6"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#486e4b"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#6fad6e"
            }
        },
        {
            "name": "StringEscapeCharacter",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#aca374"
            }
        },
        {
            "name": "Preprocessor",
            "scope": [
                "meta.attribute",
                "meta.attribute keyword",
                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#bea73c"
            }
        },
        {
            "name": "Keyword",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#979bd6"
            }
        },
        {
            "name": "Class",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.kotlin",
                "entity.name.type.enum",
                "entity.name.type.struct",
                "entity.other.inherited-class",
                "storage.type",
                "variable.other.object",
            ],
            "settings": {
                "foreground": "#35a2fa"
            }
        },
        {
            "name": "Interface",
            "scope": [
                "entity.name.type.interface",
            ],
            "settings": {
                "foreground": "#26b995"
            }
        },
        {
            "name": "Constant",
            "scope": [
                "variable.other.constant",
                "source.powershell support.constant.variable",
                "constant.other.enum",
            ],
            "settings": {
                "foreground": "#c589e7"
            }
        },
        {
            "name": "Field",
            "scope": [
                "entity.name.variable.field",
                "variable.other",
                "source.powershell support.variable",
            ],
            "settings": {
                "foreground": "#db9052"
            }
        },
        {
            "name": "Method",
            "scope": [
                "entity.name.function",
                "entity.name.variable.property",
                "variable.other.object.property",
                "source.powershell support.function"
            ],
            "settings": {
                "foreground": "#fc7676"
            }
        },
        {
            "name": "Parameter",
            "scope": [
                "variable.parameter",
                "entity.name.variable.parameter",
                "entity.name.type.type-parameter",
                "storage.type.generic",
                "source.java punctuation.bracket.angle"
            ],
            "settings": {
                "foreground": "#bea73c"
            }
        },
        {
            "name": "Number",
            "scope": [
                "constant.numeric",
            ],
            "settings": {
                "foreground": "#fa8484"
            }
        },
        {
            "name": "DocCommentTagName",
            "scope": [
                "punctuation.definition.tag",
                "keyword.other.documentation",
                "entity.name.tag",
            ],
            "settings": {
                "foreground": "#4e6350"
            }
        },
        {
            "name": "DocCommentAttributeName",
            "scope": [
                "entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#3c7063",
            }
        },
        {
            "name": "DocCommentText",
            "scope": [
                "comment.block.documentation",
                "comment.block.javadoc",
                "comment.line.documentation",
            ],
            "settings": {
                "foreground": "#667068",
            }
        },
        {
            "name": "DocCommentParameter",
            "scope": [
                "comment.block.documentation string.quoted.double",
                "comment.block.documentation punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#726427"
            }
        },
        // =====================================================================
        // XML
        // =====================================================================
        {
            "name": "XmlPunctuation",
            "scope": [
                "text.xml punctuation.definition.tag",
                "text.xml meta.tag",
            ],
            "settings": {
                "foreground": "#aca374"
            }
        },
        {
            "name": "XmlTagName",
            "scope": [
                "text.xml entity.name.tag",
            ],
            "settings": {
                "foreground": "#fc7676"
            }
        },
        {
            "name": "XmlAttributeName",
            "scope": [
                "text.xml entity.other.attribute-name",
            ],
            "settings": {
                "foreground": "#35a2fa"
            }
        },
        // =====================================================================
        // YAML/JSON
        // =====================================================================
        {
            "name": "YamlPunctuation",
            "scope": [
                "source.yaml punctuation.definition",
                "source.json punctuation.definition",
                "source.yaml punctuation.separator",
                "source.json punctuation.separator",
                "source.yaml entity.other",
            ],
            "settings": {
                "foreground": "#9faab6"
            }
        },
        {
            "name": "YamlEntityName",
            "scope": [
                "source.yaml entity.name.tag",
                "source.json support.type",
            ],
            "settings": {
                "foreground": "#35a2fa"
            }
        },
        {
            "name": "YamlConstant",
            "scope": [
                "source.yaml constant.language",
                "source.json constant.language",
            ],
            "settings": {
                "foreground": "#c589e7"
            }
        },
        // =====================================================================
        // Markdown
        // =====================================================================
        {
            "name": "Markdown Headers 1",
            "scope": [
                "heading.1 entity.name.section",
                "punctuation.definition.heading",
            ],
            "settings": {
                "foreground": "#35a2fa",
            }
        },
        {
            "name": "Markdown Headers 2",
            "scope": [
                "heading.2 entity.name.section",
            ],
            "settings": {
                "foreground": "#c589e7"
            }
        },
        {
            "name": "Markdown Headers 3",
            "scope": [
                "heading.3 entity.name.section",
            ],
            "settings": {
                "foreground": "#26b995"
            }
        },
        {
            "name": "Other Markdown Headers",
            "scope": [
                "entity.name.section",
            ],
            "settings": {
                "foreground": "#4f7696"
            }
        },
        {
            "name": "Markdown Reference Links",
            "scope": [
                "constant.other.reference.link",
            ],
            "settings": {
                "foreground": "#979bd6"
            }
        },
        {
            "name": "Markdown Links",
            "scope": [
                "markup.underline.link",
            ],
            "settings": {
                "foreground": "#26b995"
            }
        },
        {
            "name": "Markdown Punctuation",
            "scope": [
                "fenced_code.block.language",
                "markup.inline",
                "string.other.link",
                "text.html.markdown punctuation.definition",
