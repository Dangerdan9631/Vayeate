                "meta.attribute punctuation.brackets",
                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#2a5828"
            }
        },
        {
            "name": "Heavyarms Light",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#224830"
            }
        },
        {
            "name": "Heavyarms Light",
