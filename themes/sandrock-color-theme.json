                "punctuation.definition.annotation",
                "storage.type.annotation",
            ],
            "settings": {
                "foreground": "#a09060"
            }
        },
        {
            "name": "Sandrock",
            "scope": [
                "keyword",
                "constant.language",
                "storage.modifier",
                "variable.language",
            ],
            "settings": {
                "foreground": "#c0b070"
            }
        },
        {
            "name": "Sandrock",
            "scope": [
