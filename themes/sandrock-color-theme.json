    "tokenColors": [
        {
            "name": "Sandrock",
            "scope": [
                "source",
            ],
            "settings": {
                "foreground": "#a89468"
            }
        },
        // =====================================================================
        // Text
        // =====================================================================
        {
            "name": "Sandrock",
            "scope": [
                "entity.name",
                "meta.use.rust",
                "punctuation.accessor",
                "punctuation.brackets",
                "punctuation.comma",
                "punctuation.curlybrace",
                "punctuation.definition.typeparameters",
                "punctuation.definition.parameters",
                "punctuation.parenthesis",
                "punctuation.squarebracket",
                "punctuation.section",
                "punctuation.semi",
                "punctuation.separator",
                "punctuation.terminator",
                "source",
            ],
            "settings": {
                "foreground": "#d0c4a4"
            }
        },
        // =====================================================================
        // Code
        // =====================================================================
        {
            "name": "Sandrock",
            "scope": [
                "comment",
                "punctuation.definition.comment",
            ],
            "settings": {
                "foreground": "#6a5a3a"
            }
        },
        {
            "name": "Sandrock",
            "scope": [
                "string",
                "punctuation.definition.string",
            ],
            "settings": {
                "foreground": "#9a6830"
            }
        },
        {
            "name": "Sandrock",
            "scope": [
                "constant.character.escape",
                "punctuation.definition.interpolation",
            ],
            "settings": {
                "foreground": "#a87030"
            }
        },
        {
            "name": "Sandrock",
