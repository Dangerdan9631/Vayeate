root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{css,html}]
indent_style = space
indent_size = 2
tab_width = 2

[*.md]
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = false
